<div class="flex justify-between items-start mb-4">
  <div>
    <h1 class="text-2xl font-bold"><%= @patient.name %></h1>
    <p class="text-gray-500">
      <% if @patient.birthdate %><%= l @patient.birthdate rescue @patient.birthdate %> · <%= @patient.age %> anos · <% end %>
      <%= @patient.cpf %> · <%= @patient.phone %> · <%= @patient.email %>
    </p>
  </div>
  <div class="space-x-2">
    <%= link_to "Histórico", history_patient_path(@patient), class: "bg-gray-200 px-3 py-2 rounded" %>
    <%= link_to "Editar", edit_patient_path(@patient), class: "bg-gray-200 px-3 py-2 rounded" %>
  </div>
</div>

<% if @patient.notes.present? %>
  <div class="bg-yellow-50 border border-yellow-200 p-3 rounded mb-4 whitespace-pre-line text-sm"><%= @patient.notes %></div>
<% end %>

<h2 class="text-lg font-semibold mb-2">Últimas consultas</h2>
<ul class="bg-white rounded shadow divide-y">
  <% @appointments.each do |a| %>
    <li class="p-3 flex justify-between text-sm">
      <span><%= a.starts_at.strftime("%d/%m/%Y %H:%M") %> · Dr(a). <%= a.doctor.name %> · <%= a.status.humanize %></span>
      <%= link_to "Abrir", appointment_path(a), class: "text-blue-600" %>
    </li>
  <% end %>
  <% if @appointments.empty? %><li class="p-3 text-gray-500 text-sm">Sem consultas.</li><% end %>
</ul>
