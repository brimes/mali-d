<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Pacientes</h1>
  <%= link_to "Novo paciente", new_patient_path, class: "bg-blue-600 text-white px-3 py-2 rounded" %>
</div>
<table class="w-full bg-white rounded shadow text-sm">
  <thead class="bg-gray-100"><tr>
    <th class="text-left p-2">Nome</th><th class="text-left p-2">CPF</th>
    <th class="text-left p-2">Idade</th><th class="text-left p-2">Contato</th><th></th>
  </tr></thead>
  <tbody>
    <% @patients.each do |p| %>
      <tr class="border-t">
        <td class="p-2"><%= link_to p.name, patient_path(p) %></td>
        <td class="p-2"><%= p.cpf %></td>
        <td class="p-2"><%= p.age %></td>
        <td class="p-2"><%= p.phone %> <%= p.email %></td>
        <td class="p-2 text-right">
          <%= link_to "Histórico", history_patient_path(p), class: "text-blue-600 mr-2" %>
          <%= link_to "Editar", edit_patient_path(p), class: "text-blue-600" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
