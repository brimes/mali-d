<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Mali-D" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="antialiased bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
    <% if notice %>
      <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-2 shadow"><%= notice %></div>
    <% end %>
    <%= yield %>
  </body>
</html>
