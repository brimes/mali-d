<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Mali-D" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <% if user_signed_in? %>
      <header class="bg-white border-b px-6 py-3 flex justify-between items-center">
        <div class="flex items-center gap-4">
          <strong>Mali-D</strong>
          <% if current_company %>
            <span class="text-sm text-gray-500">/ <%= current_company.name %></span>
          <% end %>
        </div>
        <div class="text-sm flex items-center gap-3">
          <span><%= current_user.email %></span>
          <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "text-red-600" %>
        </div>
      </header>
    <% end %>
    <% if notice %><p class="px-6 py-2 bg-green-100 text-green-800"><%= notice %></p><% end %>
    <% if alert %><p class="px-6 py-2 bg-red-100 text-red-800"><%= alert %></p><% end %>
    <main class="flex">
      <% if user_signed_in? && current_company %>
        <nav class="w-56 p-4 border-r min-h-screen text-sm space-y-1 bg-white">
          <%= link_to "Painel", dashboard_path, class: "block px-2 py-1.5 rounded hover:bg-gray-100" %>
          <%= link_to "Agenda", appointments_path, class: "block px-2 py-1.5 rounded hover:bg-gray-100" %>
          <%= link_to "Pacientes", patients_path, class: "block px-2 py-1.5 rounded hover:bg-gray-100" %>
          <%= link_to "Médicos", doctors_path, class: "block px-2 py-1.5 rounded hover:bg-gray-100" %>
          <%= link_to "Funcionários", employees_path, class: "block px-2 py-1.5 rounded hover:bg-gray-100" %>
        </nav>
      <% end %>
      <section class="flex-1 p-6"><%= yield %></section>
    </main>
  </body>
</html>
