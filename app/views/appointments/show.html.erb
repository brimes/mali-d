<div class="flex justify-between items-start mb-4">
  <div>
    <h1 class="text-2xl font-bold">Consulta #<%= @appointment.id %></h1>
    <p class="text-gray-500">
      <%= @appointment.starts_at.strftime("%d/%m/%Y %H:%M") %> – <%= @appointment.ends_at.strftime("%H:%M") %>
      · Dr(a). <%= link_to @appointment.doctor.name, doctor_path(@appointment.doctor), class: "text-blue-600" %>
      · Paciente <%= link_to @appointment.patient.name, patient_path(@appointment.patient), class: "text-blue-600" %>
    </p>
    <span class="inline-block mt-1 text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded"><%= @appointment.status.humanize %></span>
  </div>
  <div class="space-x-2">
    <% if @appointment.medical_record %>
      <%= link_to "Abrir prontuário", appointment_medical_record_path(@appointment), class: "bg-emerald-600 text-white px-3 py-2 rounded" %>
    <% else %>
      <%= link_to "Criar prontuário", new_appointment_medical_record_path(@appointment), class: "bg-emerald-600 text-white px-3 py-2 rounded" %>
    <% end %>
    <%= link_to "Editar", edit_appointment_path(@appointment), class: "bg-gray-200 px-3 py-2 rounded" %>
    <%= button_to "Remover", appointment_path(@appointment), method: :delete,
          data: { turbo_confirm: "Remover consulta?" }, class: "bg-red-600 text-white px-3 py-2 rounded" %>
  </div>
</div>

<% if @appointment.notes.present? %>
  <div class="bg-gray-50 border p-3 rounded text-sm whitespace-pre-line"><%= @appointment.notes %></div>
<% end %>
