<h1 class="text-2xl font-bold mb-1"><%= @doctor.name %></h1>
<p class="text-gray-500 mb-4">CRM <%= @doctor.crm %> · <%= @doctor.specialty %> · <%= @doctor.active ? "Ativo" : "Inativo" %></p>
<div class="space-x-2">
  <%= link_to "Editar", edit_doctor_path(@doctor), class: "bg-gray-200 px-3 py-2 rounded" %>
  <%= button_to "Remover", doctor_path(@doctor), method: :delete,
        data: { turbo_confirm: "Remover?" }, class: "bg-red-600 text-white px-3 py-2 rounded" %>
</div>
