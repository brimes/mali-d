<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Médicos</h1>
  <%= link_to "Novo médico", new_doctor_path, class: "bg-blue-600 text-white px-3 py-2 rounded" %>
</div>

<table class="w-full bg-white rounded shadow text-sm">
  <thead class="bg-gray-100"><tr>
    <th class="text-left p-2">Nome</th><th class="text-left p-2">CRM</th>
    <th class="text-left p-2">Especialidade</th><th class="text-left p-2">Status</th><th></th>
  </tr></thead>
  <tbody>
    <% @doctors.each do |d| %>
      <tr class="border-t">
        <td class="p-2"><%= link_to d.name, doctor_path(d) %></td>
        <td class="p-2"><%= d.crm %></td>
        <td class="p-2"><%= d.specialty %></td>
        <td class="p-2"><%= d.active ? "Ativo" : "Inativo" %></td>
        <td class="p-2 text-right"><%= link_to "Editar", edit_doctor_path(d), class: "text-blue-600" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
