<h1 class="text-2xl font-bold mb-1"><%= @company.name %></h1>
<p class="text-gray-500 mb-4">
  <%= @company.kind.humanize %> · status: <%= @company.status %> ·
  acesso em
  <%= link_to "#{@company.subdomain}.lvh.me:3000", "http://#{@company.subdomain}.lvh.me:3000", target: "_blank", class: "text-blue-600 underline" %>
</p>

<div class="space-x-2">
  <%= link_to "Editar", edit_admin_company_path(@company), class: "bg-gray-200 px-3 py-2 rounded" %>
  <%= button_to "Remover", admin_company_path(@company), method: :delete,
        data: { turbo_confirm: "Apagar a empresa também derruba o schema PG. Confirma?" },
        class: "bg-red-600 text-white px-3 py-2 rounded" %>
</div>
