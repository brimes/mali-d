<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Empresas</h1>
  <%= link_to "Nova empresa", new_admin_company_path, class: "bg-blue-600 text-white px-3 py-2 rounded" %>
</div>

<table class="w-full bg-white rounded shadow text-sm">
  <thead class="bg-gray-100">
    <tr>
      <th class="text-left p-2">Nome</th>
      <th class="text-left p-2">Subdomínio</th>
      <th class="text-left p-2">Tipo</th>
      <th class="text-left p-2">Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @companies.each do |c| %>
      <tr class="border-t">
        <td class="p-2"><%= link_to c.name, admin_company_path(c) %></td>
        <td class="p-2"><code><%= c.subdomain %></code></td>
        <td class="p-2"><%= c.kind %></td>
        <td class="p-2"><%= c.status %></td>
        <td class="p-2 text-right">
          <%= link_to "Editar", edit_admin_company_path(c), class: "text-blue-600" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
