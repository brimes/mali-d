<h1 class="text-2xl font-bold mb-1"><%= current_company.name %></h1>
<p class="text-gray-500 mb-6"><%= current_company.kind.humanize %> · <%= request.host_with_port %></p>

<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="bg-white p-4 rounded shadow">
    <div class="text-sm text-gray-500">Médicos</div>
    <div class="text-3xl font-semibold"><%= @doctors_count %></div>
  </div>
  <div class="bg-white p-4 rounded shadow">
    <div class="text-sm text-gray-500">Pacientes</div>
    <div class="text-3xl font-semibold"><%= @patients_count %></div>
  </div>
  <div class="bg-white p-4 rounded shadow">
    <div class="text-sm text-gray-500">Consultas hoje</div>
    <div class="text-3xl font-semibold"><%= @appointments_today.size %></div>
  </div>
</div>

<div class="bg-white p-4 rounded shadow">
  <div class="flex justify-between items-center mb-2">
    <h2 class="text-lg font-semibold">Agenda de hoje</h2>
    <%= link_to "Ver agenda completa", appointments_path, class: "text-blue-600 text-sm" %>
  </div>
  <% if @appointments_today.any? %>
    <ul class="divide-y">
      <% @appointments_today.each do |a| %>
        <li class="py-2 flex justify-between">
          <span><%= l a.starts_at, format: :short rescue a.starts_at.strftime("%H:%M") %> · <%= a.patient.name %> com Dr(a). <%= a.doctor.name %></span>
          <%= link_to a.status.humanize, appointment_path(a), class: "text-sm text-blue-600" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-500 text-sm">Sem consultas hoje.</p>
  <% end %>
</div>
