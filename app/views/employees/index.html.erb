<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Funcionários</h1>
  <%= link_to "Novo", new_employee_path, class: "bg-blue-600 text-white px-3 py-2 rounded" %>
</div>
<table class="w-full bg-white rounded shadow text-sm">
  <thead class="bg-gray-100"><tr>
    <th class="text-left p-2">Nome</th><th class="text-left p-2">Cargo</th>
    <th class="text-left p-2">Status</th><th></th>
  </tr></thead>
  <tbody>
    <% @employees.each do |e| %>
      <tr class="border-t">
        <td class="p-2"><%= link_to e.name, employee_path(e) %></td>
        <td class="p-2"><%= e.job_title %></td>
        <td class="p-2"><%= e.active ? "Ativo" : "Inativo" %></td>
        <td class="p-2 text-right"><%= link_to "Editar", edit_employee_path(e), class: "text-blue-600" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
