<% content_for :title, "Entrar · Mali-D" %>
<% content_for :body_class, "bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 mb-4 shadow-lg shadow-blue-500/30">
        <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-white">Mali-D</h1>
      <p class="text-slate-400 mt-1 text-sm">Gestão de marcações e prontuários</p>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl p-8">
      <h2 class="text-xl font-semibold text-slate-900 mb-1">Entrar</h2>
      <p class="text-sm text-slate-500 mb-6">Acesse com suas credenciais</p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <% if alert.present? %>
          <div class="rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= alert %></div>
        <% end %>

        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                placeholder: "voce@empresa.com",
                class: "w-full rounded-lg border border-slate-300 px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none transition" %>
        </div>

        <div>
          <%= f.label :password, "Senha", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
                placeholder: "••••••••",
                class: "w-full rounded-lg border border-slate-300 px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none transition" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-2 text-sm text-slate-600">
            <%= f.check_box :remember_me, class: "rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
            Manter conectado
          </label>
        <% end %>

        <%= f.submit "Entrar",
              class: "w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold py-2.5 rounded-lg shadow-lg shadow-blue-500/30 transition cursor-pointer" %>
      <% end %>

      <% if devise_mapping.recoverable? %>
        <div class="mt-6 text-center text-sm">
          <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-blue-600 hover:text-blue-700 font-medium" %>
        </div>
      <% end %>
    </div>

    <p class="text-center text-xs text-slate-500 mt-6">
      © <%= Date.today.year %> Mali-D · Acesso restrito
    </p>
  </div>
</div>
